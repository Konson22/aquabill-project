APP_NAME="SSUWC Billing System"
APP_ENV=local
APP_KEY=base64:q1DJoJ5QrQUbvHDucVgqFWzavZeo9VHAEnsN1Z6e53w=
APP_DEBUG=true
DEBUGBAR_ENABLED=false
APP_URL=http://localhost


APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --------------------
# DATABASE: MySQL
# --------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=water_billing
DB_USERNAME=root  
DB_PASSWORD=


# --------------------
# SESSION / CACHE
# --------------------
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=file
# CACHE_PREFIX=

# --------------------
# QUEUE / BROADCAST
# --------------------
QUEUE_CONNECTION=sync
BROADCAST_CONNECTION=log

# --------------------
# FILES
# --------------------
FILESYSTEM_DISK=local


# --------------------
# VITE
# --------------------
VITE_APP_NAME="${APP_NAME}"

