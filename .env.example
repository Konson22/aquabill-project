APP_NAME=SSUWC
APP_ENV=local
APP_KEY=base64:q1DJoJ5QrQUbvHDucVgqFWzavZeo9VHAEnsN1Z6e53w=
APP_DEBUG=true
DEBUGBAR_ENABLED=false
APP_URL=http://localhost


APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --------------------
# DATABASE: MySQL
# --------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=water_billing
DB_USERNAME=root  
DB_PASSWORD=


# --------------------
# SESSION / CACHE
# --------------------
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=file
# CACHE_PREFIX=

# --------------------
# QUEUE / BROADCAST
# --------------------
QUEUE_CONNECTION=sync
BROADCAST_CONNECTION=log

# --------------------
# FILES
# --------------------
FILESYSTEM_DISK=local

# --------------------
# REDIS
# --------------------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --------------------
# MAIL
# --------------------
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --------------------
# AWS
# --------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --------------------
# VITE
# --------------------
VITE_APP_NAME="${APP_NAME}"

